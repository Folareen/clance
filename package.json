{
  "name": "clance",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@clance/web",
    "dev:api": "turbo dev --filter=@clance/api",
    "db:push": "pnpm --filter @clance/api db:push",
    "db:generate": "pnpm --filter @clance/api db:generate",
    "db:migrate": "pnpm --filter @clance/api db:migrate",
    "db:studio": "pnpm --filter @clance/api db:studio"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}
